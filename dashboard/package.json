{
  "name": "eseyasa-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:sqlite": "cross-env DATABASE_URL=file:./prisma/dev.db next dev -p 3001",
