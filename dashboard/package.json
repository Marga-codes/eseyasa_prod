    "prisma:dbpush:sqlite": "prisma db push --schema=prisma/schema.sqlite.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@vercel/blob": "^2.4.0",
    "next": "13.4.5",
    "nodemailer": "^6.9.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "cross-env": "^7.0.3",
    "prisma": "^5.0.0",
    "typescript": "^5.0.4"
  }
}
