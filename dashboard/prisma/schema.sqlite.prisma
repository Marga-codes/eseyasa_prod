datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Artist {
  id        Int      @id @default(autoincrement())
  name      String
  bio       String?
  imageUrl  String?
  links     String?
  createdAt DateTime @default(now())
}
